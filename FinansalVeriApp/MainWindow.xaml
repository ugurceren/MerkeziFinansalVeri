<Window x:Class="FinansalVeriApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FinansalVeriApp"
        mc:Ignorable="d"
        Title="Kurumsal Hesap Yönetimi" Height="600" Width="1000">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Filtre Bölümü -->
        <StackPanel Orientation="Horizontal" Margin="10" Grid.Row="0">
            <TextBlock Text="Filtre:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox x:Name="FilterTextBox" Width="200" Margin="0,0,10,0"/>
            <Button Content="Filtrele" Click="FilterButton_Click"/>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid x:Name="AccountsDataGrid" Grid.Row="1" ItemsSource="{Binding FilteredAccounts}" AutoGenerateColumns="False" Margin="10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Hesap ID" Binding="{Binding AccountId}" Width="100"/>
                <DataGridTextColumn Header="Hesap Adı" Binding="{Binding AccountName}" Width="*"/>
                <DataGridTextColumn Header="Sorumlu Ekip" Binding="{Binding ResponsibleTeam}" Width="200"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Butonlar -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="10" Grid.Row="2">
            <Button Content="Ekle" Click="AddButton_Click" Margin="0,0,10,0"/>
            <Button Content="Sil" Click="DeleteButton_Click" Margin="0,0,10,0"/>
            <Button Content="Güncelle" Click="UpdateButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
